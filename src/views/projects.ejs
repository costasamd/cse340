<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>Here are a few od our projects</p>
    <ul>
        <% projects.forEach(project => { %>
            <li><p><%= project.formatted_date %> - <a href="/project/<%= project.project_id %>"><%= project.title %></a> - <a href="/organization/<%= project.organization_id %>"><%= project.name %></a></p></li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>    